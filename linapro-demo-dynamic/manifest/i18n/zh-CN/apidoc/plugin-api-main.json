              "meta": {
                "dc": "当请求通过宿主前缀 /x/{pluginId} 以及本示例的 /api/v1 路由分组分发时，返回 linapro-demo-dynamic 当前桥接执行摘要，包括插件 ID、路由信息和当前用户上下文。",
                "summary": "查询动态插件后端执行摘要",
                "tags": "动态插件示例"
              },
              "schema": {
                "dc": "当请求通过宿主前缀 /x/{pluginId} 以及本示例的 /api/v1 路由分组分发时，返回 linapro-demo-dynamic 当前桥接执行摘要，包括插件 ID、路由信息和当前用户上下文。"
              }
