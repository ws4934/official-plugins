{
  "plugins": {
    "monitor_online": {
      "api": {
        "monitor": {
          "v1": {
            "OnlineForceLogoutReq": {
              "fields": {
                "tokenId": {
                  "dc": "要强制下线的会话Token ID"
                }
              },
              "meta": {
                "dc": "强制下线指定在线用户，被下线用户的后续请求将返回401",
                "summary": "强制下线",
                "tags": "系统监控"
              },
              "schema": {
                "dc": "强制下线指定在线用户，被下线用户的后续请求将返回401"
              }
            },
            "OnlineListReq": {
              "fields": {
                "ip": {
                  "dc": "按IP地址模糊过滤，不传则查询全部"
                },
                "username": {
                  "dc": "按用户名模糊过滤，不传则查询全部"
                }
              },
              "meta": {
                "dc": "分页查询当前在线用户会话，支持按用户名和IP地址模糊过滤",
                "summary": "在线用户列表",
                "tags": "系统监控"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "items": {
                              "dc": "在线用户列表"
                            },
                            "total": {
                              "dc": "在线用户总数"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "分页查询当前在线用户会话，支持按用户名和IP地址模糊过滤"
              }
            },
            "OnlineListRes": {
              "fields": {
                "items": {
                  "dc": "在线用户列表"
                },
                "total": {
                  "dc": "在线用户总数"
                }
              }
            },
            "OnlineUserItem": {
              "fields": {
                "browser": {
                  "dc": "浏览器"
                },
                "deptName": {
                  "dc": "部门名称"
                },
                "ip": {
                  "dc": "登录IP"
                },
                "loginTime": {
                  "dc": "登录时间，Unix 毫秒时间戳"
                },
                "os": {
                  "dc": "操作系统"
                },
                "tokenId": {
                  "dc": "会话Token ID"
                },
                "username": {
                  "dc": "登录账号"
                }
              }
            }
          }
        }
      }
    }
  }
}
