{
  "plugins": {
    "monitor_operlog": {
      "api": {
        "operlog": {
          "v1": {
            "CleanReq": {
              "fields": {
                "beginTime": {
                  "dc": "清理起始时间"
                },
                "endTime": {
                  "dc": "清理截止时间"
                }
              },
              "meta": {
                "dc": "清空指定时间范围内的操作日志，不传时间则清空全部",
                "summary": "清空操作日志",
                "tags": "操作日志"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "deleted": {
                              "dc": "实际删除的记录数"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "清空指定时间范围内的操作日志，不传时间则清空全部"
              }
            },
            "CleanRes": {
              "fields": {
                "deleted": {
                  "dc": "实际删除的记录数"
                }
              }
            },
            "DeleteReq": {
              "fields": {
                "ids": {
                  "dc": "日志ID，多个用逗号分隔"
                }
              },
              "meta": {
                "dc": "删除一条或多条操作日志记录",
                "summary": "删除操作日志",
                "tags": "操作日志"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "deleted": {
                              "dc": "实际删除的记录数"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "删除一条或多条操作日志记录"
              }
            },
            "DeleteRes": {
              "fields": {
                "deleted": {
                  "dc": "实际删除的记录数"
                }
              }
            },
            "ExportReq": {
              "fields": {
                "beginTime": {
                  "dc": "按操作时间起始筛选"
                },
                "endTime": {
                  "dc": "按操作时间结束筛选"
                },
                "ids": {
                  "dc": "指定导出的记录ID列表，不传则导出全部符合条件的记录"
                },
                "operName": {
                  "dc": "按操作人员筛选（模糊匹配）"
                },
                "operType": {
                  "dc": "按操作类型筛选：create=新增 update=修改 delete=删除 export=导出 import=导入 other=其他"
                },
                "orderBy": {
                  "dc": "排序字段：id,operTime,costTime"
                },
                "orderDirection": {
                  "dc": "排序方向：asc或desc",
                  "default": "desc"
                },
                "status": {
                  "dc": "按状态筛选：0=成功 1=失败"
                },
                "title": {
                  "dc": "按模块标题筛选（模糊匹配）"
                }
              },
              "meta": {
                "dc": "导出操作日志数据为Excel文件，支持按条件筛选导出，也支持导出指定ID的记录",
                "summary": "导出操作日志",
                "tags": "操作日志"
              },
              "schema": {
                "dc": "导出操作日志数据为Excel文件，支持按条件筛选导出，也支持导出指定ID的记录"
              }
            },
            "GetReq": {
              "fields": {
                "id": {
                  "dc": "操作日志ID"
                }
              },
              "meta": {
                "dc": "根据日志ID获取操作日志的详细信息，包括请求参数、响应结果、耗时等",
                "summary": "获取操作日志详情",
                "tags": "操作日志"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "costTime": {
                              "dc": "耗时（毫秒）"
                            },
                            "tenantId": {
                              "dc": "所属租户ID"
                            },
                            "actingUserId": {
                              "dc": "实际操作用户ID"
                            },
                            "onBehalfOfTenantId": {
                              "dc": "代表操作的目标租户ID"
                            },
                            "isImpersonation": {
                              "dc": "是否为租户代入操作"
                            },
                            "errorMsg": {
                              "dc": "错误消息"
                            },
                            "id": {
                              "dc": "日志ID"
                            },
                            "jsonResult": {
                              "dc": "返回参数"
                            },
                            "method": {
                              "dc": "方法名称"
                            },
                            "operIp": {
                              "dc": "操作IP地址"
                            },
                            "operName": {
                              "dc": "操作人员"
                            },
                            "operParam": {
                              "dc": "请求参数"
                            },
                            "operSummary": {
                              "dc": "操作摘要"
                            },
                            "operTime": {
                              "dc": "操作时间，Unix 毫秒时间戳"
                            },
                            "operType": {
                              "dc": "操作类型：create=新增 update=修改 delete=删除 export=导出 import=导入 other=其他"
                            },
                            "operUrl": {
                              "dc": "请求URL"
                            },
                            "requestMethod": {
                              "dc": "请求方式"
                            },
                            "status": {
                              "dc": "操作状态：0=成功 1=失败"
                            },
                            "title": {
                              "dc": "模块标题"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "根据日志ID获取操作日志的详细信息，包括请求参数、响应结果、耗时等"
              }
            },
