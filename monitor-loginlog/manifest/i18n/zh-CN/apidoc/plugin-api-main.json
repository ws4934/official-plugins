{
  "plugins": {
    "monitor_loginlog": {
      "api": {
        "loginlog": {
          "v1": {
            "CleanReq": {
              "fields": {
                "beginTime": {
                  "dc": "清理起始时间"
                },
                "endTime": {
                  "dc": "清理截止时间"
                }
              },
              "meta": {
                "dc": "清空指定时间范围内的登录日志，不传时间则清空全部",
                "summary": "清空登录日志",
                "tags": "登录日志"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "deleted": {
                              "dc": "实际删除的记录数"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "清空指定时间范围内的登录日志，不传时间则清空全部"
              }
            },
            "CleanRes": {
              "fields": {
                "deleted": {
                  "dc": "实际删除的记录数"
                }
              }
            },
            "DeleteReq": {
              "fields": {
                "ids": {
                  "dc": "日志ID，多个用逗号分隔"
                }
              },
              "meta": {
                "dc": "删除一条或多条登录日志记录",
                "summary": "删除登录日志",
                "tags": "登录日志"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "deleted": {
                              "dc": "实际删除的记录数"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "删除一条或多条登录日志记录"
              }
            },
            "DeleteRes": {
              "fields": {
                "deleted": {
                  "dc": "实际删除的记录数"
                }
              }
            },
            "ExportReq": {
              "fields": {
                "beginTime": {
                  "dc": "按登录时间起始筛选"
                },
                "endTime": {
                  "dc": "按登录时间结束筛选"
                },
                "ids": {
                  "dc": "指定导出的记录ID列表，不传则导出全部符合条件的记录"
                },
                "ip": {
                  "dc": "按IP地址筛选（模糊匹配）"
                },
                "orderBy": {
                  "dc": "排序字段：id,loginTime"
                },
                "orderDirection": {
                  "dc": "排序方向：asc或desc",
                  "default": "desc"
                },
                "status": {
                  "dc": "按状态筛选：0=成功 1=失败"
                },
                "userName": {
                  "dc": "按用户名筛选（模糊匹配）"
                }
              },
              "meta": {
                "dc": "导出登录日志数据为Excel文件，支持按条件筛选导出，也支持导出指定ID的记录",
                "summary": "导出登录日志",
                "tags": "登录日志"
              },
              "schema": {
                "dc": "导出登录日志数据为Excel文件，支持按条件筛选导出，也支持导出指定ID的记录"
              }
            },
            "GetReq": {
              "fields": {
                "id": {
                  "dc": "登录日志ID"
                }
              },
              "meta": {
                "dc": "根据日志ID获取登录日志的详细信息，包括登录IP、浏览器、操作系统等",
                "summary": "获取登录日志详情",
                "tags": "登录日志"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "browser": {
                              "dc": "浏览器类型"
                            },
                            "tenantId": {
                              "dc": "所属租户ID"
                            },
                            "actingUserId": {
                              "dc": "实际操作用户ID"
                            },
                            "onBehalfOfTenantId": {
                              "dc": "代表操作的目标租户ID"
                            },
                            "isImpersonation": {
                              "dc": "是否为租户代入操作"
                            },
                            "id": {
                              "dc": "日志ID"
                            },
                            "ip": {
                              "dc": "登录IP地址"
                            },
                            "loginTime": {
                              "dc": "登录时间，Unix 毫秒时间戳"
                            },
                            "msg": {
                              "dc": "提示消息"
                            },
                            "os": {
                              "dc": "操作系统"
                            },
                            "status": {
                              "dc": "登录状态：0=成功 1=失败"
                            },
                            "userName": {
                              "dc": "登录账号"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "根据日志ID获取登录日志的详细信息，包括登录IP、浏览器、操作系统等"
              }
            },
            "GetRes": {
              "fields": {
                "browser": {
                  "dc": "浏览器类型"
                },
                "tenantId": {
                  "dc": "所属租户ID"
                },
                "actingUserId": {
                  "dc": "实际操作用户ID"
                },
                "onBehalfOfTenantId": {
                  "dc": "代表操作的目标租户ID"
                },
                "isImpersonation": {
                  "dc": "是否为租户代入操作"
                },
                "id": {
                  "dc": "日志ID"
                },
                "ip": {
                  "dc": "登录IP地址"
                },
                "loginTime": {
                  "dc": "登录时间，Unix 毫秒时间戳"
                },
                "msg": {
                  "dc": "提示消息"
                },
                "os": {
                  "dc": "操作系统"
                },
                "status": {
                  "dc": "登录状态：0=成功 1=失败"
                },
                "userName": {
                  "dc": "登录账号"
                }
              }
            },
            "ListReq": {
              "fields": {
                "beginTime": {
                  "dc": "按登录时间起始筛选"
                },
                "endTime": {
                  "dc": "按登录时间结束筛选"
                },
                "ip": {
                  "dc": "按IP地址筛选（模糊匹配）"
                },
                "orderBy": {
                  "dc": "排序字段：id,loginTime"
                },
                "orderDirection": {
                  "dc": "排序方向：asc或desc",
                  "default": "desc"
                },
                "status": {
                  "dc": "按状态筛选：0=成功 1=失败"
                },
                "userName": {
                  "dc": "按用户名筛选（模糊匹配）"
                }
              },
              "meta": {
                "dc": "分页查询登录日志列表，记录用户登录成功和失败的信息，支持多条件筛选和排序",
                "summary": "获取登录日志列表",
                "tags": "登录日志"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "items": {
                              "dc": "登录日志列表"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "分页查询登录日志列表，记录用户登录成功和失败的信息，支持多条件筛选和排序"
              }
            },
            "ListRes": {
              "fields": {
                "items": {
                  "dc": "登录日志列表"
                }
              }
            },
            "LoginLogItem": {
              "fields": {
                "browser": {
                  "dc": "浏览器类型"
                },
                "tenantId": {
                  "dc": "所属租户ID"
                },
                "actingUserId": {
                  "dc": "实际操作用户ID"
                },
                "onBehalfOfTenantId": {
                  "dc": "代表操作的目标租户ID"
                },
                "isImpersonation": {
                  "dc": "是否为租户代入操作"
                },
                "id": {
                  "dc": "日志ID"
                },
                "ip": {
                  "dc": "登录IP地址"
                },
                "loginTime": {
                  "dc": "登录时间，Unix 毫秒时间戳"
                },
                "msg": {
                  "dc": "提示消息"
                },
                "os": {
                  "dc": "操作系统"
                },
                "status": {
                  "dc": "登录状态：0=成功 1=失败"
                },
                "userName": {
                  "dc": "登录账号"
                }
              }
            }
          }
        }
      }
    }
  }
}
