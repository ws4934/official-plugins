{
  "plugins": {
    "monitor_server": {
      "api": {
        "monitor": {
          "v1": {
            "CPUMetrics": {
              "fields": {
                "cores": {
                  "dc": "CPU核心数"
                },
                "modelName": {
                  "dc": "CPU型号"
                },
                "usagePercent": {
                  "dc": "CPU使用率（百分比）"
                }
              }
            },
            "DBMetrics": {
              "fields": {
                "idle": {
                  "dc": "空闲连接数"
                },
                "inUse": {
                  "dc": "使用中连接数"
                },
                "maxOpenConns": {
                  "dc": "最大连接数"
                },
                "openConns": {
                  "dc": "当前打开连接数"
                },
                "version": {
                  "dc": "数据库版本"
                }
              }
            },
            "DiskMetrics": {
              "fields": {
                "free": {
                  "dc": "可用容量（字节）"
                },
                "fsType": {
                  "dc": "文件系统类型"
                },
                "path": {
                  "dc": "挂载点路径"
                },
                "total": {
                  "dc": "总容量（字节）"
                },
                "usagePercent": {
                  "dc": "使用率（百分比）"
                },
                "used": {
                  "dc": "已用容量（字节）"
                }
              }
            },
            "GoMetrics": {
              "fields": {
                "gcPauseNs": {
                  "dc": "最近一次GC暂停时间（纳秒）"
                },
                "gfVersion": {
                  "dc": "GoFrame版本"
                },
                "goroutines": {
                  "dc": "Goroutine数量"
                },
                "processCpu": {
                  "dc": "服务CPU使用率（百分比）"
                },
                "processMemory": {
                  "dc": "服务内存使用率（百分比）"
                },
                "serviceUptime": {
                  "dc": "服务运行时长"
                },
                "version": {
                  "dc": "Go版本"
                }
              }
            },
            "MemoryMetrics": {
              "fields": {
                "available": {
                  "dc": "可用内存（字节）"
                },
                "total": {
                  "dc": "总内存（字节）"
                },
                "usagePercent": {
                  "dc": "内存使用率（百分比）"
                },
                "used": {
                  "dc": "已用内存（字节）"
                }
              }
            },
            "NetMetrics": {
              "fields": {
                "bytesRecv": {
                  "dc": "总接收字节数"
                },
                "bytesSent": {
                  "dc": "总发送字节数"
                },
                "recvRate": {
                  "dc": "接收速率（字节/秒）"
                },
                "sendRate": {
                  "dc": "发送速率（字节/秒）"
                }
              }
            },
            "ServerBasic": {
              "fields": {
                "arch": {
                  "dc": "系统架构"
                },
                "bootTime": {
                  "dc": "系统启动时间，Unix 毫秒时间戳"
                },
                "hostname": {
                  "dc": "主机名"
                },
                "os": {
                  "dc": "操作系统"
                },
                "startTime": {
                  "dc": "服务启动时间，Unix 毫秒时间戳"
                },
                "uptime": {
                  "dc": "系统运行时长（秒）"
                }
              }
            },
            "ServerMonitorReq": {
              "fields": {
                "nodeName": {
                  "dc": "按节点名称过滤，不传则返回所有节点"
                }
              },
              "meta": {
                "dc": "查询服务器监控数据，返回各节点最新的CPU、内存、磁盘、网络、Go运行时等指标信息",
                "summary": "服务监控",
                "tags": "系统监控"
              },
              "responses": {
                "200": {
                  "content": {
                    "application_json": {
                      "fields": {
                        "data": {
                          "fields": {
                            "dbInfo": {
                              "dc": "数据库指标信息"
                            },
                            "nodes": {
                              "dc": "各节点监控数据"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              },
              "schema": {
                "dc": "查询服务器监控数据，返回各节点最新的CPU、内存、磁盘、网络、Go运行时等指标信息"
              }
            },
            "ServerMonitorRes": {
              "fields": {
                "dbInfo": {
                  "dc": "数据库指标信息"
                },
                "nodes": {
                  "dc": "各节点监控数据"
                }
              }
            },
            "ServerNodeInfo": {
              "fields": {
                "collectAt": {
                  "dc": "数据上报时间，Unix 毫秒时间戳"
                },
                "cpu": {
                  "dc": "CPU指标"
                },
                "disks": {
                  "dc": "磁盘使用情况"
                },
                "goInfo": {
                  "dc": "Go运行时指标"
                },
                "memory": {
                  "dc": "内存指标"
                },
                "network": {
                  "dc": "网络流量指标"
                },
                "nodeIp": {
                  "dc": "节点IP地址"
                },
                "nodeName": {
                  "dc": "节点名称（hostname）"
                },
                "server": {
                  "dc": "服务器基本信息"
                }
              }
            }
          }
        }
      }
    }
  }
}
